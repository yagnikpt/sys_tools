#!/usr/bin/env bash
set -e

APPS=(
    "/usr/bin/steam"
    "/usr/bin/discord"
    "/usr/bin/spotify"
)

echo "[focus-off] Disabling Focus Mode..."

# Restore hosts
if [ -f /etc/hosts.normal ]; then
    cp /etc/hosts.normal /etc/hosts
    echo "[focus-off] Hosts file restored."
else
    echo "[focus-off] WARNING: /etc/hosts.normal not found. Skipping restore."
fi

# Restore app permissions
for app in "\${APPS[@]}"; do
    if [ -f "\$app" ]; then
        chmod 755 "\$app" || true
        echo "[focus-off] Unblocked app: \$app"
    fi
done

# Restart network manager (best effort)
systemctl restart NetworkManager 2>/dev/null || \
systemctl restart network-manager 2>/dev/null || true

notify-send "Focus Mode DISABLED."
