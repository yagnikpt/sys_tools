#!/usr/bin/env bash
set -e

APPS=(
    "/usr/bin/steam"
    "/usr/bin/discord"
    "/usr/bin/spotify"
)

echo "[focus-on] Enabling Focus Mode..."

# Apply hosts block
if [ -f /etc/hosts.focus ]; then
    cp /etc/hosts.focus /etc/hosts
    echo "[focus-on] Hosts file switched to focus profile."
else
    echo "[focus-on] ERROR: /etc/hosts.focus not found."
    exit 1
fi

# Block apps
for app in "\${APPS[@]}"; do
    if [ -f "\$app" ]; then
        chmod 000 "\$app" || true
        echo "[focus-on] Blocked app: \$app"
    fi
done

# Restart network manager (best effort)
systemctl restart NetworkManager 2>/dev/null || \
systemctl restart network-manager 2>/dev/null || true

notify-send "Focus Mode ENABLED."
